# bvg-display configuration
# Copy this file to .env and fill in your values.

# ── Required ─────────────────────────────────────────────
API_BASE_URL=https://v6.bvg.transport.rest
STOP_ID=900017101

# ── Optional: API ────────────────────────────────────────
API_KEY= # not needed for standard API
POLL_INTERVAL=10

# ── Optional: Display ───────────────────────────────────
# terminal | eink | lcd | web
DISPLAY_BACKEND=terminal
MAX_DEPARTURES=5

# ── Optional: Logging ───────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Uncomment to also write logs to a file:
# LOG_FILE=/var/log/transit-display.log